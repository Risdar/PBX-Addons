AddOptionMenu "PB_AddonOptions"
{
    Submenu "$PBXAddons_Settings", "PBXAddons_Menu"
}

AddOptionMenu "PBXCore_Menu"
{
    StaticText	"--------- PBX Addons Settings ---------", 1
    SafeCommand "Enable Every PBX Addons", "resetcvar PBXAddons_SettingsFlags; resetcvar PBXAddons_SmartScavFlags; resetcvar PBXAddons_DMGFeedbackFlags; resetcvar PBXAddons_WeaponUpgradesFlags;"
    SafeCommand "Reset Addons Tool Tips", "set PBXAddons_HelpFlags 0;"
    StaticText "$PBXAddons_Version",yellow
    StaticText " "
}

OptionMenu "PBXAddons_Menu"
{
    Title "$PBXAddons_Settings"
	Class "PB_OptionMenu"
    Position	-48

    StaticText	"--------- General Settings ---------", 1
    FlagOption "$PBXAddons_SmartScav_Enable",            "PBXAddons_SettingsFlags",    "OffOn", 0
    FlagOption "$PBXAddons_HelmetDrops_Enable",          "PBXAddons_SettingsFlags",    "OffOn", 1
    FlagOption "$PBXAddons_DamageIndicators_Enable",     "PBXAddons_SettingsFlags",    "OffOn", 2
    FlagOption "$PBXAddons_DamageFeedback_Enable",       "PBXAddons_SettingsFlags",    "OffOn", 3
    FlagOption "$PBXAddons_BackpackReload_Enable",       "PBXAddons_SettingsFlags",    "OffOn", 4
    FlagOption "$PBXAddons_WeaponUpgrades_Enable",       "PBXAddons_SettingsFlags",    "OffOn", 5
    SafeCommand "Enable Every PBX Addons", "resetcvar PBXAddons_SettingsFlags; resetcvar PBXAddons_SmartScavFlags; resetcvar PBXAddons_DMGFeedbackFlags; resetcvar PBXAddons_WeaponUpgradesFlags;"
    SafeCommand "Reset Addons Tool Tips", "set PBXAddons_HelpFlags 0;"
    StaticText " "
    StaticText	"--------- Individual Settings ---------", 1
    Submenu "$PBXAddons_SmartScavSettings", "PBXAddons_SmartScavengerMenu"
    Submenu "$PBXAddons_DamageIndicatorsSettings", "PBXAddons_DamageIndicatorsMenu"
    Submenu "$PBXAddons_DamageFeedbackSettings", "PBXAddons_DamageFeedbackMenu"
    Submenu "$PBXAddons_BackpackReloadSettings", "PBXAddons_BackpackReloadMenu"
    Submenu "$PBXAddons_WeaponUpgradesSettings", "PBXAddons_WeaponUpgradesMenu"
    StaticText " "
    StaticText "$PBXAddons_Version",yellow

}

OptionMenu "PBXAddons_SmartScavengerMenu"
{
    Title "$PBXAddons_SmartScavSettings"
	Class "PB_OptionMenu"
    Position	-48

    StaticText	"--------- Smart Scavenger Spawns ---------", 1
    FlagOption "$PBXAddons_SmartScav_Enable",       "PBXAddons_SettingsFlags",    "OffOn", 0
    StaticText " "
    FlagOption "$PBXAddons_SmartScav_CellPack",     "PBXAddons_SmartScavFlags",    "OffOn", 0
    FlagOption "$PBXAddons_SmartScav_ShellBox",     "PBXAddons_SmartScavFlags",    "OffOn", 1
    FlagOption "$PBXAddons_SmartScav_RocketBox",    "PBXAddons_SmartScavFlags",    "OffOn", 2
    FlagOption "$PBXAddons_SmartScav_HighCalBox",   "PBXAddons_SmartScavFlags",    "OffOn", 3
    FlagOption "$PBXAddons_SmartScav_LowCalBox",    "PBXAddons_SmartScavFlags",    "OffOn", 4
    FlagOption "$PBXAddons_SmartScav_Medikit",      "PBXAddons_SmartScavFlags",    "OffOn", 5
}

OptionMenu "PBXAddons_DamageIndicatorsMenu"
{
    Title "$PBXAddons_DamageIndicatorsSettings"
	Class "PB_OptionMenu"
    Position	-48

    StaticText	"--------- Damage Indicator Settings ---------", 1
    FlagOption "$PBXAddons_DamageIndicators_Enable",          	 "PBXAddons_SettingsFlags",    "OffOn", 2
    StaticText " "
    option "$PBXAddons_DamageIndicators_Type",                   "D4D_IndicatorType","D4DIndTypes"
	option "$PBXAddons_DamageIndicators_Colored", 				 "D4D_NoColorType","NoYes"
	slider "$PBXAddons_DamageIndicators_Scale",                  "D4D_DIScale",0.2,1.0,0.05
	slider "$PBXAddons_DamageIndicators_Alpha",                  "D4D_DIAlpha",0.05,1.0,0.05
	slider "$PBXAddons_DamageIndicators_Duration",               "D4D_DITimer",20,140,5
	option "$PBXAddons_DamageIndicators_Animation",              "D4D_DIAnim","D4DAnimTypes"
    StaticText " "
    StaticText	"--------- Damage Indicator Default Color ---------", 1
	colorpicker "$PBXAddons_DamageIndicators_ColorPicker",       "D4D_DefColor"
	textfield "$PBXAddons_DamageIndicators_Hex",                 "D4D_DefColor"
}


OptionMenu "PBXAddons_DamageFeedbackMenu"
{
    Title "$PBXAddons_DamageFeedbackSettings"
	Class "PB_OptionMenu"
    Position	-48

    StaticText	"--------- Damage Feedback Settings ---------", 1
    FlagOption "$PBXAddons_DamageFeedback_Enable",    "PBXAddons_SettingsFlags",    "OffOn", 3
    StaticText " "
    FlagOption "$PBXAddons_DMGFeedback_Print",     "PBXAddons_DMGFeedbackFlags",    "OffOn", 0
    FlagOption "$PBXAddons_DMGFeedback_Sound",     "PBXAddons_DMGFeedbackFlags",    "OffOn", 1
}

OptionMenu "PBXAddons_BackpackReloadMenu"
{
    Title "$PBXAddons_BackpackReloadSettings"
	Class "PB_OptionMenu"
    Position	-48

    StaticText	"--------- Backpack Reload Settings ---------", 1
    FlagOption "$PBXAddons_BackpackReload_Enable",            "PBXAddons_SettingsFlags",   "OffOn", 4
    StaticText " "
    slider "$PBXAddons_BackpackReload_Frequency",             "PBBCKPR_Time",1,350,5
    slider "$PBXAddons_BackpackReload_Amount",                "PBBCKPR_Ref",1,10,1
    option "$PBXAddons_BackpackReload_Announce",              "PBBCKPR_Tell","yesno"
}

OptionMenu "PBXAddons_WeaponUpgradesMenu"
